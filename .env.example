# Neo4j 连接配置（复制为 .env 并填写真实值）
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# Elasticsearch（docker compose up -d 后可用）
ES_HOST=http://localhost:9200
ES_INDEX_ENTITY=medical_entity
ES_INDEX_DOC=medical_doc
ES_ENABLED=true
ENTITY_LINK_MIN_SCORE=3.0
ENTITY_LINK_TOP_K=10

# LLM API（阶段3 RAG，OpenAI 兼容接口）
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
